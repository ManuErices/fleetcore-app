rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────

    // Admin: cualquier cuenta que NO sea @mpf.cl
    // (los admins se autentican con Google; los trabajadores con RUT@mpf.cl)
    function isAdmin() {
      return request.auth != null
          && !request.auth.token.email.matches('.*@mpf\\.cl$');
    }

    // Trabajador autenticado con su cuenta @mpf.cl
    function isTrabajador() {
      return request.auth != null
          && request.auth.token.email.matches('.*@mpf\\.cl$');
    }

    // El trabajador es dueño del documento si su uid coincide con portalUid
    // O si el docId contiene su uid
    function esMiDocumento(trabajadorId) {
      return isTrabajador()
          && exists(/databases/$(database)/documents/trabajadores/$(trabajadorId))
          && get(/databases/$(database)/documents/trabajadores/$(trabajadorId)).data.portalUid == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────
    // COLECCIONES EXCLUSIVAS DEL ADMIN
    // ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    match /contratos/{docId} {
      allow read, write: if isAdmin();
      // Trabajador puede leer sus propios contratos
      allow read: if isTrabajador()
          && resource.data.trabajadorId != null
          && esMiDocumento(resource.data.trabajadorId);
    }

    match /finiquitos/{docId} {
      allow read, write: if isAdmin();
      allow read: if isTrabajador()
          && resource.data.trabajadorId != null
          && esMiDocumento(resource.data.trabajadorId);
    }

    match /anexos/{docId} {
      allow read, write: if isAdmin();
      allow read: if isTrabajador()
          && resource.data.trabajadorId != null
          && esMiDocumento(resource.data.trabajadorId);
    }

    // ─────────────────────────────────────────────────────
    // TRABAJADORES — admin RW, trabajador lee solo el suyo
    // ─────────────────────────────────────────────────────

    // Índice uid → firestoreId del trabajador (escrito por el admin al crear cuenta portal)
    match /trabajadores_portal/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /trabajadores/{trabajadorId} {
      allow read, write: if isAdmin();
      // Trabajador lee su propio perfil (para mostrar nombre, cargo, etc.)
      allow read: if isTrabajador()
          && resource.data.portalUid == request.auth.uid;
      // Trabajador NO puede escribir su propio perfil (solo el admin)
    }

    // ─────────────────────────────────────────────────────
    // REMUNERACIONES — admin RW, trabajador lee solo las suyas
    // ─────────────────────────────────────────────────────

    match /remuneraciones/{docId} {
      allow read, write: if isAdmin();
      // Trabajador puede leer si el doc referencia su firestoreId
      // El firestoreId lo obtiene desde trabajadores_portal/{uid}.trabajadorDocId
      allow read: if isTrabajador()
          && resource.data.trabajadorId != null
          && exists(/databases/$(database)/documents/trabajadores_portal/$(request.auth.uid))
          && get(/databases/$(database)/documents/trabajadores_portal/$(request.auth.uid)).data.trabajadorDocId == resource.data.trabajadorId;
    }

    // ─────────────────────────────────────────────────────
    // ASISTENCIA — trabajador crea y lee solo la suya
    //              admin tiene acceso total
    // ─────────────────────────────────────────────────────

    match /asistencia/{docId} {
      allow read, write: if isAdmin();

      // Trabajador puede leer su propia asistencia
      allow read: if isTrabajador()
          && resource.data.trabajadorId == request.auth.uid;

      // Trabajador puede crear/actualizar su propia asistencia
      // Solo puede escribir en documentos donde trabajadorId == su uid
      allow create: if isTrabajador()
          && request.resource.data.trabajadorId == request.auth.uid;

      allow update: if isTrabajador()
          && resource.data.trabajadorId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────
    // RESTO DE COLECCIONES — solo admin
    // ─────────────────────────────────────────────────────

    match /machines/{docId}         { allow read, write: if isAdmin(); }
    match /logs/{docId}             { allow read, write: if isAdmin(); }
    match /fuel/{docId}             { allow read, write: if isAdmin(); }
    match /payroll/{docId}          { allow read, write: if isAdmin(); }
    match /oc/{docId}               { allow read, write: if isAdmin(); }
    match /rendiciones/{docId}      { allow read, write: if isAdmin(); }
    match /pasajes/{docId}          { allow read, write: if isAdmin(); }
    match /subcontratos/{docId}     { allow read, write: if isAdmin(); }
    match /consolidado/{docId}      { allow read, write: if isAdmin(); }
    match /payment_status/{docId}   { allow read, write: if isAdmin(); }
    match /fuel_prices/{docId}      { allow read, write: if isAdmin(); }
    match /reportes/{docId}         { allow read, write: if isAdmin(); }
    match /configuracion/{docId}    { allow read, write: if isAdmin(); }
    match /calendario/{docId}       { allow read, write: if isAdmin(); }

    // Colección de reportes WorkFleet (accesible también por mandantes)
    match /reporte_workfleet/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // DEFAULT — denegar todo lo no especificado
    // ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
